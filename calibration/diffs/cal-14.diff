@@ -167,6 +191,7 @@ export async function pollMergedPrs(projectPath: string): Promise<PollResult> {
     shipItPosted: [],
     shipItPending: 0,
     revertsOpened: [],
+    staleRunsReaped: reapStaleRuns().reaped,
     errors: [],
   }
 
